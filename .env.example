# AQ Designs Environment Variables

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/aqdesigns"

# NextAuth Secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI API Key (Required for AQ Designs Helper AI)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Optional: AI Model Selection (defaults to gpt-3.5-turbo)
# OPENAI_MODEL="gpt-4"
